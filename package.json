{
  "name": "todo-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "author": {
    "name": "zem-art",
    "email": "support@boba.com",
    "url": "https://mzaimzufar.my.id"
  },
  "scripts": {
    "start": "expo start",
    "start:cache": "expo start -c",
    "bump": "node update-version.js",
    "reset-project": "node ./scripts/reset-project.js",
    "lint": "expo lint",
    "dev": "expo-router dev",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "doctor": "npx expo-doctor",
    "android": "expo start --android",
    "create:branch:preview": "eas branch:create preview",
    "create:branch:prod": "eas branch:create production",
    "build:development": "eas build --platform android --profile development",
    "build:preview": "eas build --platform android --profile preview",
    "update:module": "npx expo install --check",
    "delete:module": "rm -rf node_modules pnpm-lock.yaml package-lock.json yarn.lock"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-community/netinfo": "12.0.1",
    "@react-native-picker/picker": "2.11.4",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@reduxjs/toolkit": "^2.3.0",
    "@rneui/base": "^4.0.0-rc.7",
    "@rneui/themed": "^4.0.0-rc.8",
    "dotenv": "^17.4.2",
    "expo": "^54.0.0",
    "expo-blur": "~56.0.3",
    "expo-checkbox": "~56.0.1",
    "expo-constants": "~56.0.17",
    "expo-dev-client": "~56.0.19",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-linking": "~56.0.13",
    "expo-network": "~56.0.5",
    "expo-router": "~56.2.9",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.18",
    "expo-web-browser": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-modal": "^14.0.0-rc.0",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.2",
    "react-native-webview": "13.16.1",
    "react-redux": "^9.1.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.2.14",
    "@types/react-test-renderer": "^18.3.0",
    "jest": "^29.2.1",
    "jest-expo": "~56.0.4",
    "react-test-renderer": "18.3.1",
    "typescript": "~6.0.3"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@rneui/base",
          "@rneui/themed"
        ]
      }
    }
  }
}
